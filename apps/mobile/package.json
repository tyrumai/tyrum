{
  "name": "@tyrum/mobile",
  "version": "0.1.0",
  "private": true,
  "author": "Ron Hernaus <ron@virtunet.nl>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node ./scripts/ensure-deps-built.mjs",
    "pretypecheck": "node ./scripts/ensure-deps-built.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "pnpm --dir ../.. exec vitest run apps/mobile/tests --passWithNoTests",
    "typecheck": "pnpm exec tsc --noEmit --project tsconfig.json",
    "cap:add:ios": "capacitor add ios",
    "cap:add:android": "capacitor add android",
    "cap:sync": "pnpm build && capacitor sync",
    "ios:sync": "pnpm build && capacitor sync ios",
    "android:sync": "pnpm build && capacitor sync android",
    "ios:build": "pnpm ios:sync && node ./scripts/build-ios.mjs",
    "android:build": "pnpm android:sync && node ./scripts/build-android.mjs",
    "ios:open": "pnpm ios:sync && capacitor open ios",
    "android:open": "pnpm android:sync && capacitor open android",
    "cap:open:ios": "capacitor open ios",
    "cap:open:android": "capacitor open android"
  },
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/barcode-scanner": "^3.0.2",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@tyrum/contracts": "workspace:*",
    "@tyrum/node-sdk": "workspace:*",
    "@tyrum/operator-core": "workspace:*",
    "@tyrum/operator-ui": "workspace:*",
    "@tyrum/transport-sdk": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.0"
  }
}
