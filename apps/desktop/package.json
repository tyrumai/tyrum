{
  "name": "tyrum-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.mjs",
  "scripts": {
    "dev": "electron dist/main/index.mjs",
    "build:main": "tsdown src/main/index.ts --format esm --outDir dist/main",
    "build:preload": "tsdown src/preload/index.ts --format cjs --outDir dist/preload",
    "build:renderer": "vite build",
    "build": "pnpm build:main && pnpm build:preload && pnpm build:renderer",
    "dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@tyrum/client": "workspace:*",
    "@tyrum/schemas": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.9",
    "@tyrum/gateway": "workspace:*",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.3.0"
  }
}
