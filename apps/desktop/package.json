{
  "name": "tyrum-desktop",
  "version": "0.1.0",
  "private": true,
  "author": "Ron Hernaus <ron@virtunet.nl>",
  "license": "MIT",
  "type": "module",
  "main": "dist/main/index.mjs",
  "scripts": {
    "dev": "electron dist/main/index.mjs",
    "pretest": "pnpm --filter @tyrum/schemas build && pnpm --filter @tyrum/client build && pnpm --filter @tyrum/operator-core build && pnpm --filter @tyrum/operator-ui build && pnpm --filter @tyrum/desktop-node build",
    "test": "pnpm -w vitest run apps/desktop/tests",
    "build:main": "tsdown src/main/index.ts --format esm --outDir dist/main --external electron",
    "build:preload": "tsdown src/preload/index.ts --format cjs --outDir dist/preload --external electron",
    "build:renderer": "vite build",
    "build": "pnpm build:main && pnpm build:preload && pnpm build:renderer",
    "build:gateway": "pnpm --filter @tyrum/schemas build && pnpm --filter @tyrum/gateway build && node ./scripts/stage-gateway-bin.mjs",
    "icons:generate": "node ./scripts/generate-icons.mjs",
    "dist": "pnpm build:gateway && pnpm build && electron-builder --publish never"
  },
  "dependencies": {
    "@tyrum/desktop-node": "workspace:*",
    "@tyrum/operator-core": "workspace:*",
    "@tyrum/operator-ui": "workspace:*",
    "electron-updater": "^6.6.2",
    "playwright": "^1.58.2",
    "tesseract.js": "^7.0.0",
    "undici": "^7.24.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fiahfy/icns": "0.0.7",
    "@fiahfy/ico": "0.0.5",
    "@hono/node-server": "^1.19.11",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@tyrum/gateway": "workspace:*",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.0"
  }
}
