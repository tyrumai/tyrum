{
  "name": "Tyrum",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "24.0"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24",
      "installYarn": true
    },
    "ghcr.io/devcontainers/features/rust:1": {
      "profile": "default"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.13"
    },
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "1.13.3"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "hashicorp.terraform",
        "redhat.vscode-yaml"
      ]
    }
  },
  "remoteUser": "vscode",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "containerEnv": {
    "CARGO_REGISTRIES_CRATES_IO_PROTOCOL": "sparse"
  },
  "postCreateCommand": "npm install -g npm@11.6.0 && pip install --user pre-commit && pre-commit install",
  "updateContentCommand": "npm install --prefix web && cargo fetch && terraform -chdir=infra/terraform/bootstrap init -backend=false",
  "workspaceFolder": "/workspaces/tyrum",
  "forwardPorts": [3000, 8080, 8081]
}
