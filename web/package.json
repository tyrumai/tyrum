{
  "name": "tyrum-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:single": "pnpm --filter @tyrum/gateway build && node ./scripts/start-single-instance.mjs",
    "lint": "eslint .",
    "test": "node ./scripts/run-tests.mjs",
