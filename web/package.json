  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@tyrum/gateway": "workspace:*",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "axe-core": "4.11.1",
    "eslint": "10.0.0",
    "eslint-config-next": "16.1.6",
    "jsdom": "28.1.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "vitest-axe": "0.1.0"
  }
}
