# syntax=docker/dockerfile:1.7

ARG BASE_IMAGE=ghcr.io/rhernaus/tyrum/base-images/python:3.11-slim
FROM ${BASE_IMAGE}

ENV VLLM_MODEL=hf-internal-testing/tiny-random-LlamaForCausalLM \
    VLLM_MODEL_NAME=tyrum-stub \
    VLLM_HOST=0.0.0.0 \
    VLLM_PORT=8000 \
    VLLM_EXTRA_ARGS=

COPY docker/vllm-entrypoint.sh /usr/local/bin/vllm-entrypoint
RUN chmod 0755 /usr/local/bin/vllm-entrypoint

EXPOSE 8000

ENTRYPOINT ["/usr/local/bin/vllm-entrypoint"]
