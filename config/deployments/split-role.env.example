# split-role reference profile (gateway-edge/worker/scheduler, Postgres)
#
# Usage (local processes):
#   export GATEWAY_TOKEN="$(openssl rand -hex 32)"
#   set -a && source config/deployments/split-role.env.example && set +a
#   tyrum edge
#   tyrum worker
#   tyrum scheduler
#
# Usage (docker compose):
#   cp config/deployments/split-role.env.example config/local.env
#   # edit config/local.env to set GATEWAY_TOKEN
#   docker compose --env-file config/local.env --profile split up -d --build postgres tyrum-edge tyrum-worker tyrum-scheduler

TYRUM_HOME=/var/lib/tyrum
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8788

# Required: shared admin token across all split-role processes (>=32 chars).
GATEWAY_TOKEN=

# Split-role requires Postgres.
POSTGRES_USER=tyrum
POSTGRES_PASSWORD=tyrum
POSTGRES_DB=tyrum
GATEWAY_DB_PATH=postgres://tyrum:tyrum@postgres:5432/tyrum

# Split-role should not rely on shared filesystem secrets.
TYRUM_SECRET_PROVIDER=env

# Transport posture (pick one):
# - TYRUM_TLS_READY=1 after configuring TLS termination (recommended)
# - TYRUM_ALLOW_INSECURE_HTTP=1 for trusted networks only
TYRUM_TLS_READY=1

# Enable durable workflow APIs and engine-backed WS control plane.
TYRUM_ENGINE_API_ENABLED=1

