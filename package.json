{
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "pretypecheck": "pnpm --filter @tyrum/schemas build && pnpm --filter @tyrum/client build && node -e \"require('node:fs').rmSync('packages/schemas/tsconfig.tsbuildinfo',{force:true})\"",
    "build": "pnpm -r run build",
    "pretest": "pnpm --filter @tyrum/schemas build && pnpm --filter @tyrum/client build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "docs:public-check": "bash scripts/check-public-docs.sh",
    "lint": "oxlint --ignore-pattern '**/dist/**' .",
    "format": "node scripts/format-repo.mjs --write",
    "format:check": "node scripts/format-repo.mjs --check",
    "format:check-staged": "node scripts/format-changed.mjs --check --staged",
    "typecheck": "tsc -b"
  },
  "pnpm": {
    "overrides": {
      "@develar/schema-utils>ajv": "8.18.0",
      "@develar/schema-utils>ajv-keywords": "5.1.0",
      "dmg-license>ajv": "8.18.0",
      "file-loader>schema-utils": "4.3.3",
      "minimatch": "10.2.1",
      "null-loader>schema-utils": "4.3.3",
      "rollup": "4.59.0",
      "tmp": ">=0.2.4",
      "url-loader>schema-utils": "4.3.3"
    },
    "patchedDependencies": {
      "@develar/schema-utils@2.6.5": "patches/@develar__schema-utils@2.6.5.patch",
      "dmg-license@1.0.11": "patches/dmg-license@1.0.11.patch"
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "oxlint": "^1.50.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
