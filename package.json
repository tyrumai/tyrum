{
  "private": true,
  "author": "Ron Hernaus <ron@virtunet.nl>",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "api:generate": "node scripts/generate-api-artifacts.mjs",
    "api:check": "node scripts/check-generated-api.mjs",
    "ci": "pnpm ci:ubuntu",
    "ci:ubuntu": "pnpm install --frozen-lockfile && pnpm typecheck && pnpm exec tsc --noEmit --project apps/desktop/tsconfig.json && pnpm lint && pnpm i18n:check && pnpm format:check && pnpm build && pnpm --filter tyrum-desktop exec playwright install chromium && bash scripts/xvfb-run-safe.sh -a --server-args=\"-screen 0 1920x1080x24\" -- pnpm test --coverage.enabled --coverage.reporter=text-summary",
    "icons:generate": "pnpm --filter tyrum-desktop icons:generate",
    "i18n:extract": "node scripts/i18n-extract.mjs",
    "i18n:check": "node scripts/i18n-check.mjs",
    "prepare": "node scripts/setup-githooks.mjs && node scripts/check-file-type-patch.mjs",
    "setup:githooks": "node scripts/setup-githooks.mjs",
    "pretypecheck": "node scripts/ensure-typecheck-builds.mjs && node scripts/clear-typecheck-build-info.mjs",
    "build": "pnpm -r run build",
    "clean": "find apps packages -type d -name dist -prune -exec rm -rf {} +",
    "test:prepare": "node scripts/check-native-sqlite.mjs && node scripts/ensure-test-builds.mjs",
    "pretest": "pnpm test:prepare",
    "test": "vitest run",
    "pretest:watch": "pnpm test:prepare",
    "test:a11y:operator-ui": "vitest run packages/operator-ui/tests/operator-ui.a11y.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "docs:public-check": "bash scripts/check-public-docs.sh",
    "lint": "pnpm lint:boundaries && node scripts/lint/oxlint-ratchet.mjs && node scripts/lint/check-raw-elements.mjs",
    "lint:boundaries": "node scripts/lint/check-package-boundaries.mjs",
    "lint:oxlint:report": "oxlint -f unix .",
    "format": "node scripts/format-repo.mjs --write",
    "format:check": "node scripts/format-repo.mjs --check",
    "format:check-staged": "node scripts/format-changed.mjs --check --staged",
    "typecheck": "tsc -b && pnpm --filter @tyrum/mobile typecheck"
  },
  "pnpm": {
    "overrides": {
      "@develar/schema-utils>ajv": "8.18.0",
      "@develar/schema-utils>ajv-keywords": "5.1.0",
      "@modelcontextprotocol/sdk>express-rate-limit": "8.3.0",
      "dmg-license>ajv": "8.18.0",
      "dbus-next>xml2js": "0.5.0",
      "fast-xml-parser": "5.5.7",
      "file-loader>schema-utils": "4.3.3",
      "brace-expansion": "5.0.5",
      "dompurify": "3.3.2",
      "immutable": "4.3.8",
      "minimatch": "10.2.4",
      "node-forge": "1.4.0",
      "null-loader>schema-utils": "4.3.3",
      "rollup": "4.59.0",
      "serialize-javascript": "7.0.3",
      "svgo": "3.3.3",
      "tar": "7.5.11",
      "tmp": ">=0.2.4",
      "yauzl": "3.2.1",
      "url-loader>schema-utils": "4.3.3",
      "usocket>node-gyp": "11.5.0"
    },
    "patchedDependencies": {
      "app-builder-lib@26.8.1": "patches/app-builder-lib@26.8.1.patch",
      "@develar/schema-utils@2.6.5": "patches/@develar__schema-utils@2.6.5.patch",
      "dmg-license@1.0.11": "patches/dmg-license@1.0.11.patch",
      "file-type@16.5.4": "patches/file-type@16.5.4.patch",
      "native-run@2.0.3": "patches/native-run@2.0.3.patch",
      "prebuild-install@7.1.3": "patches/prebuild-install@7.1.3.patch",
      "usocket@0.3.0": "patches/usocket@0.3.0.patch"
    },
    "allowUnusedPatches": true,
    "auditConfig": {
      "ignoreCves": [
        "CVE-2026-31808"
      ]
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "core-js",
      "core-js-pure",
      "electron",
      "electron-winstaller",
      "esbuild",
      "protobufjs",
      "tesseract.js",
      "usocket"
    ]
  },
  "devDependencies": {
    "astral-regex": "^2.0.0",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.2",
    "oxlint": "^1.57.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.6",
    "typescript": "^6.0.2",
    "verror": "1.10.1",
    "vitest": "^4.1.2",
    "vitest-axe": "^0.1.0"
  }
}
