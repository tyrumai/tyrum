{
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "pretypecheck": "pnpm --filter @tyrum/schemas build && node -e \"require('node:fs').rmSync('packages/schemas/tsconfig.tsbuildinfo',{force:true})\"",
    "build": "pnpm -r --filter './packages/*' run build",
    "pretest": "pnpm --filter @tyrum/schemas build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "oxlint --ignore-pattern '**/dist/**' .",
    "typecheck": "tsc -b"
  },
  "pnpm": {
    "overrides": {
      "tmp": ">=0.2.4"
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "oxlint": "^1.48.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
