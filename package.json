{
  "private": true,
  "author": "Ron Hernaus <ron@virtunet.nl>",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "api:generate": "node scripts/generate-api-artifacts.mjs",
    "api:check": "node scripts/check-generated-api.mjs",
    "ci": "pnpm ci:local",
    "ci:local": "node scripts/run-local-ci.mjs",
    "ci:ubuntu": "node scripts/run-local-ci.mjs --linux",
    "icons:generate": "pnpm --filter tyrum-desktop icons:generate",
    "i18n:extract": "node scripts/i18n-extract.mjs",
    "i18n:check": "node scripts/i18n-check.mjs",
    "prepare": "node scripts/setup-githooks.mjs",
    "setup:githooks": "node scripts/setup-githooks.mjs",
    "pretypecheck": "node scripts/ensure-typecheck-builds.mjs && node scripts/clear-typecheck-build-info.mjs",
    "build": "pnpm -r run build",
    "clean": "find apps packages -type d -name dist -prune -exec rm -rf {} +",
    "test:prepare": "node scripts/check-native-sqlite.mjs && node scripts/ensure-test-builds.mjs",
    "pretest": "pnpm test:prepare",
    "test": "vitest run",
    "pretest:watch": "pnpm test:prepare",
    "test:a11y:operator-ui": "vitest run packages/operator-ui/tests/operator-ui.a11y.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "docs:public-check": "bash scripts/check-public-docs.sh",
    "lint": "pnpm lint:boundaries && node scripts/lint/oxlint-ratchet.mjs && node scripts/lint/check-raw-elements.mjs",
    "lint:boundaries": "node scripts/lint/check-package-boundaries.mjs",
    "lint:oxlint:report": "oxlint -f unix .",
    "format": "node scripts/format-repo.mjs --write",
    "format:check": "node scripts/format-repo.mjs --check",
    "format:check-staged": "node scripts/format-changed.mjs --check --staged",
    "typecheck": "tsc -b && pnpm --filter @tyrum/mobile typecheck"
  },
  "devDependencies": {
    "astral-regex": "^2.0.0",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.7",
    "oxlint": "^1.67.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "verror": "1.10.1",
    "vitest": "^4.1.7",
    "vitest-axe": "^0.1.0"
  }
}
