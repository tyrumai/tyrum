{
  "name": "@tyrum/node-sdk",
  "version": "0.1.0",
  "author": "Ron Hernaus <ron@virtunet.nl>",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./browser": {
      "types": "./dist/browser.d.mts",
      "import": "./dist/browser.mjs"
    },
    "./node": {
      "types": "./dist/node.d.mts",
      "import": "./dist/node.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/browser.ts src/node.ts --format esm --dts"
  },
  "dependencies": {
    "@tyrum/contracts": "workspace:*",
    "@tyrum/transport-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "ws": "^8.20.0"
  }
}
