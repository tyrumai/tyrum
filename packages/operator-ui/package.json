{
  "name": "@tyrum/operator-ui",
  "version": "0.1.0",
  "author": "Ron Hernaus <ron@virtunet.nl>",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./pages": {
      "types": "./dist/pages.d.mts",
      "import": "./dist/pages.mjs"
    },
    "./globals.css": {
      "types": "./src/globals.css.d.ts",
      "default": "./src/globals.css"
    }
  },
  "files": [
    "dist",
    "src/*.css",
    "src/*.css.d.ts",
    "src/themes/*.css"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/pages.ts --format esm --dts"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.140",
    "@fontsource-variable/dm-sans": "^5.2.5",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tailwindcss/typography": "^0.5.16",
    "@tyrum/operator-app": "workspace:*",
    "@tyrum/contracts": "workspace:*",
    "ai": "^6.0.138",
    "clsx": "^2.1.1",
    "lucide-react": "^1.6.0",
    "qrcode": "^1.5.4",
    "react-intl": "^10.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.2"
  }
}
