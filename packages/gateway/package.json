{
  "name": "@tyrum/gateway",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "tyrum": "./bin/tyrum.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "bin"
