    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@tyrum/schemas": "workspace:*",
    "ai": "^6.0.91",
    "better-sqlite3": "^12.6.2",
    "hono": "^4.11.10",
    "mitt": "^3.0.1",
    "pg": "^8.18.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
