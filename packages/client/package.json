{
  "name": "@tyrum/client",
  "version": "0.1.0",
  "author": "Ron Hernaus <ron@virtunet.nl>",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./browser": {
      "types": "./dist/browser.d.mts",
      "import": "./dist/browser.mjs"
    },
    "./node": {
      "types": "./dist/node.d.mts",
      "import": "./dist/node.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/browser.ts src/node.ts --format esm --dts"
  },
  "dependencies": {
    "@tyrum/schemas": "workspace:*",
    "mitt": "^3.0.1",
    "undici": "^7.22.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.11",
    "@types/ws": "^8.18.1",
    "hono": "^4.12.5",
    "ws": "^8.19.0"
  }
}
